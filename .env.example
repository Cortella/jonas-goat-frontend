# Frontend environment variables for local development.
# Copy this to .env if you need client-side config.

# Add VITE_ prefixed keys below.
# Example:
# VITE_API_BASE_URL=http://127.0.0.1:8765

# Login com Google — Client ID do OAuth (mesmo valor do GOOGLE_CLIENT_ID no
# backend). Precisa estar presente no BUILD (o Vite embute no bundle). Em
# produção, defina nas Environment Variables da Vercel. Sem ele, o botão Google
# simplesmente não aparece.
# VITE_GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com

# ─── Rastreamento de campanha (Google Analytics 4 + Google Ads) ──────────────
# Tudo é opcional: enquanto vazio, NENHUMA tag é carregada (app roda igual, sem
# rastreamento). Precisa estar no BUILD — defina nas Environment Variables da
# Vercel para produção. Ver src/lib/analytics.ts.
#
# GA4 — Measurement ID. Crie em https://analytics.google.com → Admin → Fluxos
# de dados → Web. Formato G-XXXXXXXXXX.
# VITE_GA4_ID=G-XXXXXXXXXX
#
# Google Ads — ID da conta (tag global). JÁ TEM PADRÃO no código
# (AW-18274300909, ver src/lib/analytics.ts); só defina para sobrescrever.
# VITE_GADS_ID=AW-XXXXXXXXX
#
# Google Ads — label da ação de conversão de COMPRA. JÁ TEM PADRÃO no código
# (ação "Compra" da conta acima); só defina para sobrescrever. É a parte
# depois da barra no "send_to": AW-XXXXXXXXX/ESTE_LABEL.
# VITE_GADS_PURCHASE_LABEL=AbCdEfGhIjKl
